{
  "name": "whatsapp-bot-interpreter",
  "version": "1.0.0",
  "description": "No-code WhatsApp bot interpreter using Baileys",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "fun": "node fun/start.js",
    "fun:dev": "node --watch fun/start.js",
    "fun:dashboard": "npm --prefix fun_dashboard run dev -- --port 3001",
    "fun:dashboard:build": "npm --prefix fun_dashboard run build",
    "fun:dashboard:start": "npm --prefix fun_dashboard run start -- --port 3001",
    "test": "node --test --import ./tests/test-env-setup.js tests/*.test.js",
    "dashboard:dev": "npm --prefix tmb_dashboard run dev",
    "dashboard:build": "npm --prefix tmb_dashboard run build",
    "dashboard:lint": "npm --prefix tmb_dashboard run lint"
  },
  "dependencies": {
    "@whiskeysockets/baileys": "^6.7.16",
    "baileys": "^7.0.0-rc.9",
    "better-sqlite3": "^12.8.0",
    "blessed": "^0.1.81",
    "inquirer": "^9.2.20",
    "pino": "^8.19.0",
    "pino-pretty": "^11.0.0",
    "qrcode-terminal": "^0.12.0",
    "sharp": "^0.35.3",
    "skia-canvas": "^3.0.8"
  }
}
